{
  "browser": "@zen_browser@",
  "rules": [
    {
      "pattern": "^https://zoom.us/j/",
      "mods": [
        {
          "action": "url_replace",
          "data": [
            "https://zoom.us/j/(\\d+)",
            "zoommtg://zoom.us/join?confno=$1"
          ]
        }
      ]
    },
    {
      "pattern": "^https://zoom.us/s/",
      "mods": [
        {
          "action": "url_replace",
          "data": [
            "https://zoom.us/s/(\\d+)",
            "zoommtg://zoom.us/start?confno=$1"
          ]
        }
      ]
    },
    {
      "pattern": "^https://docs\\.google\\.com/(presentation|document|spreadsheets)/d/[^/]+/edit",
      "mods": [
        {
          "action": "url_replace",
          "data": [
            "^(https://docs\\.google\\.com/(?:presentation|document|spreadsheets)/d/[^/]+)/edit.*",
            "$1/preview"
          ]
        }
      ]
    },
    {
      "pattern": "^https://meet.google.com",
      "cmd": "@google_chrome@"
    }
  ]
}
