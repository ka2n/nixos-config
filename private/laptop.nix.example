# Copy to laptop.nix and fill in your values.
#
# The file is committed with dummy values so Nix flakes can see it.
# To keep your real values out of git status, set skip-worktree:
#
#   git update-index --skip-worktree private/laptop.nix
#
# To undo (e.g. before pulling changes to the template):
#
#   git update-index --no-skip-worktree private/laptop.nix
{
  domains = ["your-tenant.onmicrosoft.com"];
  username = "user@example.com";
}
